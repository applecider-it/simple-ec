<div class="swiper-container swiper-container1">
  <div class="swiper swiper1">
    <div class="swiper-wrapper">
      <% list.each do |val| %>
        <div class="swiper-slide">
          <img src="<%= val %>" alt="" class="mx-auto" />
        </div>
      <% end %>
    </div>

    <div class="swiper-pagination swiper-pagination1"></div>
  </div>
</div>