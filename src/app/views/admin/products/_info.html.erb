<div class="my-3">
  <%= form.label :created_at, class: "app-form-label" %>
  <%= product.created_at.strftime("%Y-%m-%d %H:%M") %>
</div>

<div class="my-3">
  <%= form.label :discarded_at, class: "app-form-label" %>
  <%= product.discarded_at ? product.discarded_at.strftime("%Y-%m-%d %H:%M") : 'none' %>
</div>

